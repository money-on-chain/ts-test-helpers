{
  "name": "ts-test-helpers",
  "version": "0.1.0",
  "private": true,
  "description": "Internal test helper package for Money On Chain repos",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "hardhat clean && rm -rf dist artifacts cache",
    "compile": "hardhat compile",
    "build": "pnpm exec tsc -p tsconfig.build.json",
    "check": "pnpm exec tsc --noEmit",
    "prepare": "pnpm build",
    "test": "pnpm clean && pnpm compile && pnpm check && node --import tsx/esm --test \"test/**/*.test.ts\""
  },
  "dependencies": {
    "viem": "2.53.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "5.0.7",
    "@openzeppelin/contracts": "4.9.3",
    "@openzeppelin/contracts-ethereum-package": "3.0.0",
    "@openzeppelin/upgrades": "2.8.0",
    "@types/node": "^26.0.1",
    "hardhat": "3.9.0",
    "solc": "0.6.12",
    "tsx": "^4.22.4",
    "typechain": "^8.3.2",
    "typescript": "6.0.3"
  }
}
