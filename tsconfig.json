{
    "compilerOptions": {
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "lib": ["es6"],
        "module": "NodeNext",
        "target": "es2022",
        "moduleResolution": "NodeNext",
        "noImplicitAny": true,
        "outDir": "dist",
        "rootDir": "src",
        "resolveJsonModule": true,
        "allowImportingTsExtensions": false,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "types": ["hardhat", "node"]
    },
    "include": ["src/**/*"],
    "exclude": ["dist/**/*", "test/**/*"]
}
